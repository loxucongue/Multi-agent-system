# Database connection URL (local MySQL)
DATABASE_URL=mysql+aiomysql://root:CHANGE_ME@127.0.0.1:3306/travel_db

# Redis connection URL (local Memurai/Redis)
REDIS_URL=redis://127.0.0.1:6379/0

# DeepSeek configuration
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Coze OAuth and workflow configuration
COZE_OAUTH_APP_ID=
COZE_KID=
COZE_PRIVATE_KEY_PATH=
COZE_WF_ROUTE_SEARCH_ID=
COZE_WF_VISA_SEARCH_ID=
COZE_WF_EXTERNAL_INFO_ID=
COZE_SPACE_ID=
COZE_ROUTE_DATASET_ID=
COZE_VISA_DATASET_ID=

# Admin authentication configuration
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# JWT secret for backend authentication/session token
JWT_SECRET_KEY=

# Session configuration
SESSION_CONTEXT_TURNS=6
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Seed data source (optional, for seed_data.py)
SEED_EXCEL_PATH=
