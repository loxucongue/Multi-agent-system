# Database connection URL (local MySQL)
DATABASE_URL=mysql+aiomysql://root:CHANGE_ME@127.0.0.1:3306/travel_db

# Redis connection URL (local Memurai/Redis)
REDIS_URL=redis://127.0.0.1:6379/0

# DeepSeek configuration
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Coze OAuth and workflow configuration
COZE_OAUTH_APP_ID=
COZE_KID=
COZE_PRIVATE_KEY_PATH=
# Coze 路线搜索工作流 ID
COZE_WF_ROUTE_SEARCH_ID=
# Coze 签证搜索工作流 ID
COZE_WF_VISA_SEARCH_ID=
# Coze 外部信息查询工作流 ID
COZE_WF_EXTERNAL_INFO_ID=
# Coze 行程文档解析工作流 ID（当前使用: 7589597800921727019）
COZE_WF_ROUTE_PARSE_ID=
# 解析工作流最大并发数（建议不超过 Coze 账号的 QPS 限制）
COZE_PARSE_CONCURRENCY=10
COZE_SPACE_ID=
COZE_ROUTE_DATASET_ID=
COZE_VISA_DATASET_ID=

# Admin authentication configuration
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# JWT secret for backend authentication/session token
JWT_SECRET_KEY=

# Session configuration
SESSION_CONTEXT_TURNS=6
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|10\\.\\d+\\.\\d+\\.\\d+|172\\.(1[6-9]|2\\d|3[0-1])\\.\\d+\\.\\d+|192\\.168\\.\\d+\\.\\d+)(:\\d+)?$

# Seed data source (optional, for seed_data.py)
SEED_EXCEL_PATH=
